# ========== 项目路径配置 ==========
# 项目根目录（建议使用绝对路径）
PROJECT_ROOT=D:\Backup\PythonProject2\VetRAG

# 模型路径
# Qwen3 原始模型
Qwen3_MODEL_PATH=D:\Backup\PythonProject2\VetRAG\models\Qwen3-0.6B\qwen\Qwen3-0___6B
# Qwen3 微调后模型
QWEN3_FINETUNED_PATH=D:\Backup\PythonProject2\VetRAG\models_finetuned\qwen3-finetuned
# Qwen3 微调后模型 (版本1)
QWEN3_FINETUNED_PATH_V1=D:\Backup\PythonProject2\VetRAG\models_finetuned\qwen3-finetuned1

# ========== 向量数据库配置 ==========
# ChromaDB 持久化目录
CHROMA_PERSIST_DIR=./chroma_db
# ChromaDB collection 名称
CHROMA_COLLECTION_NAME=veterinary_rag

# ========== Embedding 模型配置 ==========
# BGE 向量化模型
BGE_MODEL_NAME=BAAI/bge-large-zh-v1.5
# 备选（轻量级）
BGE_MODEL_FALLBACK=paraphrase-multilingual-MiniLM-L12-v2

# ========== Hugging Face 配置 ==========
# 使用镜像站加速下载（国内推荐）
HF_ENDPOINT=https://hf-mirror.com

# ========== FastAPI 服务配置 ==========
API_HOST=0.0.0.0
API_PORT=8000
# 生产环境请改为具体域名
API_CORS_ORIGINS=*

# ========== 数据目录配置 ==========
DATA_DIR=./data
# 知识库 JSON 文件列表（逗号分隔）
DATA_FILES=behaviors.json,breeds.json,cares.json,diseases.json,surgeries.json

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=./logs/vetrag.log
