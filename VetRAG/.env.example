# ========== Ollama 配置 ==========
# Ollama 服务地址
OLLAMA_BASE_URL=http://localhost:11434
# 答案生成模型（微调版）
OLLAMA_GENERATOR_MODEL=vetrag-qwen3-1.7b-vet
# 领域守卫模型（基础版）
OLLAMA_GUARD_MODEL=qwen3:1.7b

# ========== DeepSeek API（LLM-as-Judge 评分用）==========
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ========== 向量数据库配置 ==========
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=veterinary_rag

# ========== Embedding 模型配置 ==========
BGE_MODEL_NAME=BAAI/bge-large-zh-v1.5
BGE_MODEL_FALLBACK=paraphrase-multilingual-MiniLM-L12-v2

# ========== 混合检索配置 ==========
USE_HYBRID_SEARCH=false
HYBRID_DENSE_WEIGHT=0.7
HYBRID_BM25_WEIGHT=0.3
HYBRID_RRF_K=60

# ========== FastAPI 服务配置 ==========
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*

# ========== 数据目录配置 ==========
DATA_DIR=./data
DATA_FILES=behaviors.json,breeds.json,cares.json,diseases.json,surgeries.json,pharmaceuticals.json

# ========== Hugging Face 配置 ==========
HF_ENDPOINT=https://hf-mirror.com
HF_TOKEN=your_huggingface_token_here

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=./logs/vetrag.log
